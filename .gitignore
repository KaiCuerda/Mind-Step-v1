import tkinter as tk
from tkinter import messagebox

# --- CONFIGURACIÓN ESTÉTICA (TU LIBRETA) ---
COLOR_FONDO = "#1e1e1e"  # Gris casi negro (descanso visual)
COLOR_TEXTO = "#FFFFFF"   # Blanco puro
FONT_TITULO = ("Segoe UI", 20, "bold") # Fuente moderna y limpia
FONT_BOTON = ("Segoe UI", 12, "bold")

# Colores Pastel para los botones (suaves, no agresivos)
COLOR_ALTA = "#ffb3b3"   # Rojo suave
COLOR_MEDIA = "#b3ffb3"  # Verde suave
COLOR_BAJA = "#b3d9ff"   # Azul suave
COLOR_BOTON_TEXTO = "#333333" # Gris oscuro para el texto del botón

# --- LÓGICA ---
def mostrar_plan(nivel):
    if nivel == "Alta":
        tarea = "Estudiar Python y IA."
        consejo = "Aprovecha el hiperfoco, socio."
    elif nivel == "Media":
        tarea = "Ordenar habitación / Deberes."
        consejo = "Paso a paso, sin prisas."
    else:
        tarea = "Jugar GTA V / Descansar."
        consejo = "Desconecta el cerebro un rato."
        
    messagebox.showinfo(f"Nivel {nivel}", f"TAREA: {tarea}\n\nCONSEJO: {consejo}")

# --- VENTANA PRINCIPAL ---
root = tk.Tk()
root.title("Minimal Focus TEA")
root.geometry("450x550")
root.configure(bg=COLOR_FONDO)

# --- INTERFAZ GRÁFICA SIMPLE ---

# 1. Espaciador superior (para dar aire)
tk.Frame(root, height=40, bg=COLOR_FONDO).pack()

# 2. Título centrado y limpio
titulo = tk.Label(root, text="MI BATERÍA HOY", 
                  fg=COLOR_TEXTO, bg=COLOR_FONDO, font=FONT_TITULO)
titulo.pack(pady=10)

subtitulo = tk.Label(root, text="Selecciona tu nivel de energía:", 
                     fg="#aaaaaa", bg=COLOR_FONDO, font=("Segoe UI", 10))
subtitulo.pack(pady=(0, 30))

# 3. Contenedor para los botones (para alinearlos)
contenedor = tk.Frame(root, bg=COLOR_FONDO)
contenedor.pack(pady=10)

# --- CREACIÓN DE BOTONES "ESTILO TARJETA" ---
# Usamos 'relief="flat"' y 'pady' interno para dar sensación de pastilla plana.

btn_alta = tk.Button(contenedor, text="ENERGÍA ALTA", 
                     bg=COLOR_ALTA, fg=COLOR_BOTON_TEXTO, font=FONT_BOTON,
                     relief="flat", width=25, pady=15,
                     command=lambda: mostrar_plan("Alta"))
btn_alta.pack(pady=15)

btn_media = tk.Button(contenedor, text="ENERGÍA MEDIA", 
                      bg=COLOR_MEDIA, fg=COLOR_BOTON_TEXTO, font=FONT_BOTON,
                      relief="flat", width=25, pady=15,
                     command=lambda: mostrar_plan("Media"))
btn_media.pack(pady=15)

btn_baja = tk.Button(contenedor, text="ENERGÍA BAJA", 
                     bg=COLOR_BAJA, fg=COLOR_BOTON_TEXTO, font=FONT_BOTON,
                     relief="flat", width=25, pady=15,
                     command=lambda: mostrar_plan("Baja"))
btn_baja.pack(pady=15)

# 4. Pie de página decorativo
tk.Label(root, text="v1.0 | Creado por un Ingeniero de 15 años", 
         fg="#555555", bg=COLOR_FONDO, font=("Arial", 8)).pack(side="bottom", pady=20)

root.mainloop()
